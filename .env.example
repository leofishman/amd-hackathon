# Copy to .env before `docker compose up`.
# Requires an AMD GPU (ROCm) host — /dev/kfd + /dev/dri must exist. This is
# the point of the hackathon; the bundled `ollama:rocm` image will fail to
# start without them.

# AMD GPU inference endpoint (OpenAI-compatible, e.g. vLLM on ROCm).
# Leave empty to use the bundled ollama:rocm service instead.
# On minisforum after cleanup:
#   AMD_VLLM_URL=http://172.17.0.1:11435/v1
#   (or http://host.docker.internal:11435/v1)
AMD_VLLM_URL=

# Fireworks (reliable fallback, uses your credits).
FIREWORKS_API_KEY=

# Comma-separated Ollama models pulled at first boot.
OLLAMA_MODELS=gemma3:4b

# Local model (entity id) that verifies answers on the route; rejection
# escalates to the best candidate. Empty = disabled.
AGENT_VERIFIER_MODEL=

# Admin password for site install. ALWAYS set a strong one for a public demo.
ADMIN_PASS=admin

# Optional: relay the factcheck module's admin alert emails (scan run,
# settings changed) to Telegram too. This box has no working outbound mail;
# reuses the existing ops bot. Empty = relay disabled (email is still tried,
# it just won't deliver here). See modules/amd_hackathon/amd_hackathon.module.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
