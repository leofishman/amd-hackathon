# Copy to .env before `docker compose up`.

# Remote / AMD inference.
# AMD_VLLM_URL: OpenAI-compatible endpoint.
#   - Notebook vLLM via tunnel, or
#   - Minisforum ROCm Ollama (recommended when notebook quota is limited).
#     Example: http://localhost:11435/v1   (see MINISFORUM_ROCM.md)
# When present, factcheck + route prefer this (shows as "AMD Instinct GPU").
AMD_VLLM_URL=

# Fireworks (reliable fallback, uses your credits).
FIREWORKS_API_KEY=

# Comma-separated Ollama models pulled at first boot (CPU fallback inside compose).
OLLAMA_MODELS=gemma3:4b

# Local model (entity id) that verifies answers on the route; rejection
# escalates to the best candidate. Empty = disabled.
AGENT_VERIFIER_MODEL=
